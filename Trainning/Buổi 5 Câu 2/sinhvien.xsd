<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:element name="DanhSachSinhVien">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="SinhVien" type="SinhVienType" maxOccurs="unbounded"></xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:complexType name="SinhVienType">
        <xs:sequence>
            <xs:element name="HoTen" type="xs:string"></xs:element>
            <xs:element name="Lop" type="LopType"></xs:element>
            <xs:element name="DanhsachMonHoc" type="DanhSachMonHocType"></xs:element>
        </xs:sequence>
        <xs:attribute name="MSSV" type="MSSVType"></xs:attribute>
    </xs:complexType>

    <xs:simpleType name="LopType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="TBK50DH"></xs:enumeration>
            <xs:enumeration value="TBK50CD"></xs:enumeration>
            <xs:enumeration value="TBK51DH"></xs:enumeration>
            <xs:enumeration value="TBK51CD"></xs:enumeration>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="MSSVType">
        <xs:restriction base="xs:string">
            <xs:pattern value="\d{8}"></xs:pattern>
        </xs:restriction>
    </xs:simpleType>

    <xs:complexType name="DanhSachMonHocType">
        <xs:sequence>
            <xs:element name="MonHoc" type="MonHocType" maxOccurs="unbounded"></xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="MonHocType">
        <xs:sequence>
            <xs:element name="TenMonHoc" type="xs:string"></xs:element>
            <xs:element name="TinChi" type="TinChiType"></xs:element>
            <xs:element name="DiemMonHoc" type="DiemMonHocType"></xs:element>
        </xs:sequence>
        <xs:attribute name="MaMon" type="MaMonType"></xs:attribute>
    </xs:complexType>

    <xs:simpleType name="TinChiType">
        <xs:restriction base="xs:int">
            <xs:minInclusive value="1"></xs:minInclusive>
            <xs:maxInclusive value="5"></xs:maxInclusive>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="MaMonType">
        <xs:restriction base="xs:string">
            <xs:pattern value="[A-Za-z]{2}\d{2}"></xs:pattern>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="DiemMonHocType">
        <xs:restriction base="xs:decimal">
            <xs:minInclusive value="0"></xs:minInclusive>
            <xs:maxInclusive value="10"></xs:maxInclusive>
        </xs:restriction>
    </xs:simpleType>
</xs:schema>